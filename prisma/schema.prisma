generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Role {
  super_admin
  publik
  admin
  pegawai
  kepala_balai
}

enum StatusAkun {
  active
  inactive
}

enum StatusTiket {
  diajukan
  menunggu_verifikasi
  perlu_revisi
  menunggu_pembayaran
  diproses
  selesai_diproses
  menunggu_konfirmasi
  selesai
  ditolak
  dibatalkan
}

enum StatusBayar {
  menunggu
  lunas
  batal
}

enum KanalNotifikasi {
  dashboard
  email
}

model User {
  id             Int         @id @default(autoincrement())
  email          String?     @unique
  password       String
  nama           String
  nip            String?     @unique
  no_hp          String?
  role           Role        @default(publik)
  status_akun    StatusAkun  @default(active)
  unit_teknis_id Int?
  unit_teknis    UnitTeknis? @relation(fields: [unit_teknis_id], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tikets      Tiket[]
  notifikasis Notifikasi[]
  auditLogs   AuditLog[]

  @@map("users")
}

model UnitTeknis {
  id        Int      @id @default(autoincrement())
  nama      String
  users     User[]
  tikets    Tiket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("unit_teknis")
}

model Layanan {
  id           Int      @id @default(autoincrement())
  nama_layanan String
  biaya        Json
  sla_hari     Int?
  form_schema  Json
  tikets       Tiket[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("layanan")
}

model Tiket {
  id             Int         @id @default(autoincrement())
  no_tiket       String      @unique
  user_id        Int
  user           User        @relation(fields: [user_id], references: [id])
  layanan_id     Int
  layanan        Layanan     @relation(fields: [layanan_id], references: [id])
  jawaban_form   Json?
  status         StatusTiket @default(diajukan)
  tanggal_submit DateTime    @default(now())
  tanggal_sla    DateTime?
  unit_teknis_id Int?
  unit_teknis    UnitTeknis? @relation(fields: [unit_teknis_id], references: [id])

  dokumen    Dokumen[]
  tagihan    Tagihan?
  notifikasi Notifikasi[]
  auditLog   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tiket")
}

model Dokumen {
  id             Int      @id @default(autoincrement())
  tiket_id       Int
  tiket          Tiket    @relation(fields: [tiket_id], references: [id])
  nama_file      String
  tipe           String
  url_storage    String
  tanggal_upload DateTime @default(now())

  @@map("dokumen")
}

model Tagihan {
  id            Int         @id @default(autoincrement())
  tiket_id      Int         @unique
  tiket         Tiket       @relation(fields: [tiket_id], references: [id])
  jumlah        Int
  status_bayar  StatusBayar @default(menunggu)
  bukti_bayar   String?
  tanggal_lunas DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tagihan")
}

model Notifikasi {
  id           Int             @id @default(autoincrement())
  user_id      Int
  user         User            @relation(fields: [user_id], references: [id])
  tiket_id     Int?
  tiket        Tiket?          @relation(fields: [tiket_id], references: [id])
  kanal        KanalNotifikasi
  pesan        String          @db.Text
  status_kirim Boolean         @default(false)
  timestamp    DateTime        @default(now())

  @@map("notifikasi")
}

model AuditLog {
  id               Int      @id @default(autoincrement())
  user_id          Int?
  user             User?    @relation(fields: [user_id], references: [id])
  tiket_id         Int?
  tiket            Tiket?   @relation(fields: [tiket_id], references: [id])
  aksi             String
  detail_perubahan String?  @db.Text
  timestamp        DateTime @default(now())

  @@map("audit_log")
}